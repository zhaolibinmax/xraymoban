{
  "log": {
    "loglevel": "warning"
    },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks"
    },
     {
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http"
     }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "111111111111",    // 此处填写你使用的 CDN 的 IP 或 域名
            "port": 443,
            "users": [
              {
                "id": "1111111111",    // 与服务端一致
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "tag": "PROXY:XHTTP+TLS",
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "1111111111",    // 与服务端一致
          "allowInsecure": false,    // 仅客户端设置
          "alpn": ["h2"],    // h2 已非常丝滑，如果你使用的 CDN 支持 h3 且你所在地区对 UDP 的 QoS 不严重，可以填 "h3"
          "fingerprint": "chrome"
        },
        "xhttpSettings": {
          "host": "1111111111",    // 过CDN时必须填 host
          "path": "/1111111111",    // 不要照抄，尽可能将 path 设置得复杂一些，与服务端保持一致
          "mode": "auto"
        }
      }
    }
  ]
        }
